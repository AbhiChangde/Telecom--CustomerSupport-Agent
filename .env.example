GEMINI_API_KEY=GEMINI_API_KEY
SARVAM_API_KEY=SARVAM_API_KEY
PINECONE_API_KEY=your_pinecone_api_key
PINECONE_INDEX_NAME=telesupport-memory
VECTOR_DB_PROVIDER=pinecone
USE_MOCK_CRM=true
USE_MOCK_STT=false
USE_MOCK_VECTOR_DB=true       # set false to enable ChromaDB memory (requires chromadb + sentence-transformers)
USE_MOCK_SMS=true
USE_MOCK_OUTAGE=true
USE_MOCK_TTS=false
USE_MOCK_SER=false        # set true to skip SER model (no torch needed)
